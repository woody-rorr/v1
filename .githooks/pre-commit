#!/bin/bash
# console.log 있으면 커밋 차단

FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|jsx|tsx)$')

if [ -z "$FILES" ]; then
  exit 0
fi

FOUND=$(echo "$FILES" | xargs grep -n "console\.log" 2>/dev/null)

if [ -n "$FOUND" ]; then
  echo "❌ [pre-commit] console.log 발견 — 커밋 차단"
  echo "$FOUND"
  echo ""
  echo "제거 후 다시 커밋하세요."
  exit 1
fi

exit 0
